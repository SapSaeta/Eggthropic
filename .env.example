# Eggthropic environment variables
# Copy this file to .env.local for local development

# Site URL (used for absolute URLs in metadata and sitemap)
NEXT_PUBLIC_SITE_URL=https://eggthropic.com

# Anthropic API key (required for any live Claude API experiments)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=your_api_key_here

# Optional: Claude model to use for API experiments
# Default: claude-sonnet-4-6 (or replace with latest recommended model)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Analytics (add your provider's ID here if using analytics)
# NEXT_PUBLIC_ANALYTICS_ID=your_id_here
